# Default: treat all files as text, normalize to LF in the index.
# Git will auto-detect binary files and skip them.
* text=auto eol=lf

# Explicit text declarations (defence-in-depth against auto-detection failures)
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.ps1       text eol=lf
*.cmd       text eol=lf
*.bat       text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf

# Explicit binary declarations
*.jar       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pem       binary
